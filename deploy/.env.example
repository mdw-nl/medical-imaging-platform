# ---------------------------------------------------------------
# Copy this file to .env and fill in every value marked REQUIRED.
# docker compose up will refuse to start if any are left blank.
# ---------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # REQUIRED — choose a strong password
POSTGRES_DB=testdb

XNAT_VERSION=1.8.10
XNAT_MIN_HEAP=256m
XNAT_MAX_HEAP=1g
XNAT_SMTP_ENABLED=false
XNAT_SMTP_HOSTNAME=fake.fake
XNAT_SMTP_PASSWORD=         # REQUIRED
XNAT_DATASOURCE_USERNAME=xnat
XNAT_DATASOURCE_PASSWORD=   # REQUIRED
XNAT_DATASOURCE_NAME=xnat
XNAT_EMAIL=admin@example.com

XNAT_API_USER=admin
XNAT_API_PASSWORD=           # REQUIRED
XNAT_ADMIN_USER=admin
XNAT_ADMIN_PASSWORD=         # REQUIRED — XNAT initial setup credentials

UPLOAD_DESTINATION=postgres

GRAFANA_USER=admin
GRAFANA_PASSWORD=            # REQUIRED

USE_NIFTI=true
LOG_LEVEL=INFO

IMAGING_API_KEY=             # REQUIRED — shared API key for inter-service auth

# Set to "require" when Postgres is configured with a server certificate
# IMAGING_POSTGRES__SSLMODE=require

# --- Imaging-hub performance tuning ---
# DICOM_PORT=104                  # Host port mapped to the DICOM listener
# STAGING_TMPFS_SIZE=2g           # RAM-disk size for DICOM staging (counts against container memory)
# POOL_MAX_WORKERS=4              # Parallel anonymization worker processes
# QUEUE_MAX_SIZE=0                # Max queued files awaiting processing (0 = unlimited)
