    {
      "id": 40,
      "title": "Avg Receive+Anonymize (s/patient)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "pipeline-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(EXTRACT(EPOCH FROM duration))::numeric, 1) FROM (SELECT patient_id, MAX(timestamp) - MIN(timestamp) AS duration FROM dicom_insert GROUP BY patient_id HAVING COUNT(*) > 1) sub",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 43,
