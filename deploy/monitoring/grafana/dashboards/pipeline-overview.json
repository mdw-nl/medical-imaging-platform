    {
      "id": 65,
      "title": "Per-Patient XNAT Completeness",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "pipeline-postgres"
      },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT pa.patient_id, SUM(CASE WHEN pa.modality='CT' AND pa.xnat_status='verified' THEN 1 ELSE 0 END) as ct_verified, SUM(CASE WHEN pa.modality='RTSTRUCT' AND pa.xnat_status='verified' THEN 1 ELSE 0 END) as rtstruct_verified, SUM(CASE WHEN pa.modality='RTDOSE' AND pa.xnat_status='verified' THEN 1 ELSE 0 END) as rtdose_verified, SUM(CASE WHEN pa.modality='RTPLAN' AND pa.xnat_status='verified' THEN 1 ELSE 0 END) as rtplan_verified, SUM(CASE WHEN pa.xnat_status='pending' THEN 1 ELSE 0 END) as pending, SUM(CASE WHEN pa.xnat_status='conflict' THEN 1 ELSE 0 END) as conflicts FROM pacs_archive pa GROUP BY pa.patient_id ORDER BY pa.patient_id",
          "format": "table",
          "refId": "A"
