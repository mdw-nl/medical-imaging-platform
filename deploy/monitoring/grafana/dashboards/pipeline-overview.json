        "defaults": {
          "decimals": 1
        }
      },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT ROUND((COUNT(*)::numeric / NULLIF(EXTRACT(EPOCH FROM (MAX(timestamp) - MIN(timestamp))), 0))::numeric, 1) FROM dicom_insert",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
