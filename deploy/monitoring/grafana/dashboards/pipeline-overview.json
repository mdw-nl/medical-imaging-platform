    {
      "id": 22,
      "title": "Patient Pipeline Status",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "pipeline-postgres"
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "nifti_failed"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "transparent",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT p.generated_patient_id AS patient_id, COALESCE(ct.n, 0) AS ct_files, COALESCE(rs.n, 0) AS rtstruct, COALESCE(rd.n, 0) AS rtdose, COALESCE(rp.n, 0) AS rtplan, COALESCE(nc.completed, 0) AS nifti_ok, COALESCE(nc.failed, 0) AS nifti_failed, COALESCE(nc.masks, 0) AS masks, COALESCE(dvh.rois, 0) AS dvh_rois, COALESCE(rad.jobs, 0) AS radiomics, ROUND(EXTRACT(EPOCH FROM (di_t.last_file - di_t.first_file))::numeric, 1) AS anon_secs FROM patient_id_map p LEFT JOIN (SELECT patient_id, COUNT(*) n FROM dicom_insert WHERE modality='CT' GROUP BY 1) ct ON ct.patient_id = p.generated_patient_id LEFT JOIN (SELECT patient_id, COUNT(*) n FROM dicom_insert WHERE modality='RTSTRUCT' GROUP BY 1) rs ON rs.patient_id = p.generated_patient_id LEFT JOIN (SELECT patient_id, COUNT(*) n FROM dicom_insert WHERE modality='RTDOSE' GROUP BY 1) rd ON rd.patient_id = p.generated_patient_id LEFT JOIN (SELECT patient_id, COUNT(*) n FROM dicom_insert WHERE modality='RTPLAN' GROUP BY 1) rp ON rp.patient_id = p.generated_patient_id LEFT JOIN (SELECT patient_id, SUM(CASE WHEN status='completed' THEN 1 ELSE 0 END) completed, SUM(CASE WHEN status='failed' THEN 1 ELSE 0 END) failed, SUM(COALESCE(mask_count,0)) masks FROM nifti_conversion GROUP BY 1) nc ON nc.patient_id = p.generated_patient_id LEFT JOIN (SELECT di.patient_id, COUNT(DISTINCT dp.roi_name) rois FROM dvh_package dp JOIN dicom_insert di ON dp.sop_instance_uid = di.sop_instance_uid GROUP BY 1) dvh ON dvh.patient_id = p.generated_patient_id LEFT JOIN (SELECT di.patient_id, COUNT(DISTINCT rm.radiomics_id) jobs FROM radiomics_manager rm JOIN dicom_insert di ON rm.sop_instance_uid = di.sop_instance_uid GROUP BY 1) rad ON rad.patient_id = p.generated_patient_id LEFT JOIN (SELECT patient_id, MIN(timestamp) AS first_file, MAX(timestamp) AS last_file FROM dicom_insert GROUP BY patient_id) di_t ON di_t.patient_id = p.generated_patient_id ORDER BY p.generated_patient_id",
          "format": "table",
          "refId": "A"
        }
      ]
    },
