          "unit": "s",
          "decimals": 1
        }
      },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN COUNT(*) > 1 THEN ROUND((EXTRACT(EPOCH FROM (MAX(timestamp) - MIN(timestamp))) / NULLIF(COUNT(*) - 1, 0))::numeric, 1) END FROM calculation_status WHERE status = TRUE",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 44,
      "title": "Avg PACS Archive (s/patient)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 6,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "pipeline-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(EXTRACT(EPOCH FROM duration))::numeric, 1) FROM (SELECT patient_id, MAX(archived_at) - MIN(queued_at) AS duration FROM pacs_archive WHERE status = 'archived' GROUP BY patient_id) sub",
          "format": "table",
          "refId": "A"
