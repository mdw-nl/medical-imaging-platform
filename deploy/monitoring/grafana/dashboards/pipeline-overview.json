      "datasource": {
        "type": "postgres",
        "uid": "pipeline-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "targets": [
        {
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(EXTRACT(EPOCH FROM (nc.completed_at - di.first_received)))::numeric, 1) FROM nifti_conversion nc JOIN (SELECT patient_id, MIN(timestamp) AS first_received FROM dicom_insert GROUP BY patient_id) di ON di.patient_id = nc.patient_id WHERE nc.status = 'completed'",
          "format": "table",
          "refId": "A"
        }
      ]
